      "Text": [
        {
          "x": 1320,
          "y": -20,
          "objectType": "Text",
          "label": "Operation:\n\n* Select a program to run with the input box pointed at by\n  the red arrow labeled  Program Select.\n\n* Select the initial values for the tape in the boxes at the bottom of the screen, \n  pointed at by the arrow labeled Initial Values.\n\n* Press the Reset button to the bottom left.\n\n* Program has finished when the red Halted LED turns on.\n\n* Program might also halt if there is an overflow on the tape at either end. \n  On a normal halt, the LEDs at both ends should be off, \n  otherwise, there had been an overflow\n\nYou may restart the program at any time with the Reset button.\n",
          "direction": "RIGHT",
          "labelDirection": "LEFT",
          "propagationDelay": 10,
          "customData": {
            "constructorParamaters": [
              "Operation:\n\n* Select a program to run with the input box pointed at by\n  the red arrow labeled  Program Select.\n\n* Select the initial values for the tape in the boxes at the bottom of the screen, \n  pointed at by the arrow labeled Initial Values.\n\n* Press the Reset button to the bottom left.\n\n* Program has finished when the red Halted LED turns on.\n\n* Program might also halt if there is an overflow on the tape at either end. \n  On a normal halt, the LEDs at both ends should be off, \n  otherwise, there had been an overflow\n\nYou may restart the program at any time with the Reset button.\n",
              18
            ]
          }
        }
